# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Admin credentials (server-side only — never exposed to the browser) ──────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_something_strong

# ── Session signing secret ────────────────────────────────────────────────────
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this secret invalidates all active sessions.
SESSION_SECRET=

# ── Public site URL (no trailing slash) ──────────────────────────────────────
# Used for OG tags, sitemap, and robots.txt.
NEXT_PUBLIC_SITE_URL=https://your-domain.co.il
